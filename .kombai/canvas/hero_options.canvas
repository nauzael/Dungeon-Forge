      "html": "<script data-asset-crawler data-kid=\"2\">\n(function() {\n  var q = {};\n  window.__crawlAsset = function(el) {\n    var url = el.dataset.originalSrc || el.dataset.originalHref || el.src || el.href;\n    if (!url || q[url]) return;\n    q[url] = true;\n    fetch('http://localhost:19722/api/assets/crawl', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ url: url, canvasPath: \".kombai/canvas/hero_options.canvas\", nodeId: \"text_69f599ef16e6\" })\n    }).then(function(r) {\n      if (!r.ok) console.warn('[AssetCrawler] crawl response not ok:', r.status, url);\n    }).catch(function(e) {\n      console.warn('[AssetCrawler] crawl fetch failed:', e.message || e, url);\n    });\n  };\n})();\n</script><div style=\"font-size: 16px;\" data-kid=\"0\"><br data-kid=\"1\"></div>\n",
