/**
 * Firebase Storage Security Rules for Dungeon Forge
 * 
 * Wave 2: CORS + OTA Configuration
 * Purpose: Allow public read of version.json for OTA updates
 *          Protect other files with authentication
 */

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ════════════════════════════════════════════════════════════════════════
    // /version.json — PUBLIC READ (for OTA update checks)
    // ════════════════════════════════════════════════════════════════════════
    match /version.json {
      allow read: if true;  // Public read
      allow write: if request.auth != null;  // Only authenticated users can upload
    }
    
    // ════════════════════════════════════════════════════════════════════════
    // /builds/*.apk — PUBLIC READ (for APK downloads)
    // ════════════════════════════════════════════════════════════════════════
    match /builds/{document=**} {
      allow read: if true;  // Public read for APK downloads
      allow write: if request.auth != null;  // Only authenticated users can upload
    }
    
    // ════════════════════════════════════════════════════════════════════════
    // All other paths — PROTECTED (authenticated access only)
    // ════════════════════════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
